# ── 앱 설정 ───────────────────────────────────────────
DEBUG=false
KERAS_MODEL_VERSION=v1
KERAS_THRESHOLD=0.3

# ── ITS(교통정보시스템) CCTV API ──────────────────────
ITS_API_KEY=your_its_api_key
ITS_API_BASE_URL=https://openapi.its.go.kr:9443/cctvInfo

# ── 연동 서버 주소 ─────────────────────────────────────
AI_BACKEND_URL=http://localhost:8000
AI_SERVER_URL=http://localhost:8001

# ── AI 서버 API 인증 ───────────────────────────────────
# 비워두면 X-Api-Key 검증을 건너뜁니다.
AI_API_KEY=your_ai_server_api_key

# ── DB (ai_db) ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=ai_db
