# ── 데이터베이스 ──────────────────────────────────────
# member_db — 사용자·관리자 계정
DB_MEMBER_HOST=localhost
DB_MEMBER_PORT=3306
DB_MEMBER_NAME=member_db
DB_MEMBER_USER=member_user
DB_MEMBER_PASSWORD=your_db_password

# board_db — 공지·문의·FAQ·자료실·버그 게시판
DB_BOARD_HOST=localhost
DB_BOARD_PORT=3306
DB_BOARD_NAME=board_db
DB_BOARD_USER=board_user
DB_BOARD_PASSWORD=your_db_password

# ai_db — CCTV·감지 기록·금지 클래스 (AI 서버 담당)
DB_AI_HOST=localhost
DB_AI_PORT=3306
DB_AI_NAME=ai_db
DB_AI_USER=ai_user
DB_AI_PASSWORD=your_db_password

# chat_db — AI 챗봇 세션·메시지
DB_CHAT_HOST=localhost
DB_CHAT_PORT=3306
DB_CHAT_NAME=chat_db
DB_CHAT_USER=chat_user
DB_CHAT_PASSWORD=your_db_password

# ── JWT ───────────────────────────────────────────────
JWT_SECRET_KEY=your_super_secret_jwt_key_min_32chars
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=480

# ── 이메일 (SMTP) ─────────────────────────────────────
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM=your_email@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_TLS=True
MAIL_SSL=False

# ── 인증 코드 만료 (분) ───────────────────────────────
EMAIL_CODE_EXPIRE_MINUTES=10

# ── ITS API ───────────────────────────────────────────
# 한국 교통정보시스템(ITS) CCTV 목록 동기화 API 키
ITS_API_KEY=your_its_api_key

# ── 이미지 저장 ───────────────────────────────────────
IMAGE_SAVE_DIR=./captures
IMAGE_BASE_URL=http://localhost:8000/images

# ── AI 챗봇 ───────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key

# ── 소셜 로그인 ───────────────────────────────────────
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_REDIRECT_URI=http://localhost:8000/auth/naver/callback

KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=http://localhost:8000/auth/kakao/callback

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── 관리자 초기 계정 ─────────────────────────────────
ADMIN_LOGIN_ID=admin
ADMIN_PASSWORD=Admin1234!
ADMIN_EMAIL=admin@roadeye.local
ADMIN_NAME=관리자

# ── CORS 설정 ───────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGIN2=http://localhost:3001
FRONTEND_AUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# ── AI 서버 주소 ───────────────────────────────────────
AI_SERVER_URL=http://localhost:8001
AI_API_KEY=your_ai_server_api_key
